# ===== Frontend (client-safe, exposed to browser) =====
NEXT_PUBLIC_HUSH_CONTRACT=0x...
# Sepolia cUSDT (Mock) — ERC-7984 confidential token used for payments
NEXT_PUBLIC_PAYMENT_TOKEN=0x4E7B06D78965594eB5EF5414c357ca21E1554491
NEXT_PUBLIC_PAYMENT_TOKEN_UNDERLYING=0xa7dA08FafDC9097Cc0E7D4f113A61e31d7e8e9b0
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ===== Server-only (NEVER prefix with NEXT_PUBLIC_) =====
# Used only in Next.js API routes / server components to verify onchain
# subscription state before returning gated content. The anon publishable
# key above is the only key shipped to the browser.
SUPABASE_SERVICE_ROLE=eyJ...

# ===== Supabase SQL (run once in SQL Editor) =====
# CREATE TABLE IF NOT EXISTS posts (
#   id BIGSERIAL PRIMARY KEY,
#   creator_address TEXT NOT NULL,
#   creator_name TEXT NOT NULL DEFAULT '',
#   title TEXT NOT NULL,
#   preview TEXT NOT NULL DEFAULT '',
#   content TEXT NOT NULL DEFAULT '',
#   tier_index INTEGER NOT NULL DEFAULT 0,
#   created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
# );
# ALTER TABLE posts ENABLE ROW LEVEL SECURITY;
# -- Public can read only the preview (title + preview, never full content)
# CREATE POLICY "Public reads previews" ON posts FOR SELECT USING (true);
# -- Writes are mediated by the server (service role); anon cannot write.
# -- (INSERT/UPDATE/DELETE policies intentionally omitted for the anon key.)
